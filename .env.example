# Chat General Configuration
# Copy this file to .env and fill in your values

# Server Configuration
CHAT__SERVER__HOST=0.0.0.0
CHAT__SERVER__PORT=8080

# Database Configuration
CHAT__DATABASE__HOST=localhost
CHAT__DATABASE__PORT=5432
CHAT__DATABASE__USERNAME=postgres
CHAT__DATABASE__PASSWORD=your_password_here
CHAT__DATABASE__DATABASE=chat_general

# Redis Configuration
CHAT__REDIS__HOST=localhost
CHAT__REDIS__PORT=6379
CHAT__REDIS__PASSWORD=
CHAT__REDIS__DATABASE=0

# JWT Configuration
CHAT__JWT__SECRET=your-jwt-secret-key-change-in-production
CHAT__JWT__ACCESS_TOKEN_EXPIRY=3600
CHAT__JWT__REFRESH_TOKEN_EXPIRY=604800

# Environment (development, staging, production)
CHAT_ENV=development
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/chat_test